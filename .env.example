# Public site URL — where the app runs (Vercel URL or custom domain). Used for magic link redirects.
NEXT_PUBLIC_SITE_URL=https://unblck.cl

# Resend — sender must be on a domain you verified in Resend (not *.vercel.app)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=UNBLCK <noreply@yourdomain.com>

# Supabase (required for form submissions and authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin allowlist + shared password (password login, no magic link)
ADMIN_EMAILS=admin@unblck.com
ADMIN_PASSWORD=change-this-before-seeding

# Agent API key for external Telegram/WhatsApp bots
AGENT_API_KEY=change-this-to-secure-random-key

# Terms & Conditions version
TERMS_VERSION=2026-07-01

# Buttondown — newsletter subscriber API (https://buttondown.com/settings/programming)
BUTTONDOWN_API_KEY=btn_xxxxxxxx

# Sozu Wallet redirect URL for coffee redemption (must be NEXT_PUBLIC_ for client-side link)
NEXT_PUBLIC_SOZU_WALLET_URL=https://credit.sozu.capital
