# Public site URL — where the app runs (Vercel URL or custom domain). Used for magic link redirects.
NEXT_PUBLIC_SITE_URL=https://unblck-landing.vercel.app

# Resend — sender must be on a domain you verified in Resend (not *.vercel.app)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=UNBLCK <noreply@yourdomain.com>

# Supabase (required for form submissions and authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin allowlist + shared password (password login, no magic link)
ADMIN_EMAILS=admin@unblck.com
ADMIN_PASSWORD=change-this-before-seeding

# Terms & Conditions version
TERMS_VERSION=2026-07-01

# Sozu Wallet redirect URL for coffee redemption
SOZU_WALLET_URL=https://sozuwallet.app
